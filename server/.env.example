# --- Database ---
DATABASE_URL=postgresql://lam:lam@localhost:5432/lam

# --- Server ---
PORT=4000
NODE_ENV=development
# Public base URL used to build absolute URLs for locally stored uploads
PUBLIC_BASE_URL=http://localhost:4000

# --- Auth ---
# Set to "true" to accept the x-dev-user header instead of Firebase ID tokens
# (local development / tests only — NEVER enable in production)
DEV_AUTH_BYPASS=true

# --- Firebase (optional in dev; required in production) ---
# Path to the service account JSON, or leave empty and use
# FIREBASE_SERVICE_ACCOUNT_JSON with the inlined JSON (Railway-friendly)
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=

# --- AI microservice ---
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=change-me-shared-secret

# --- Suggestion engine ---
# Days a look is considered "recently worn" and excluded from suggestions
ANTI_REPEAT_DAYS=14

# --- Barcode lookup (add clothes by scanning their tag) ---
# UPCitemdb-compatible endpoint. The default free trial needs no key but is
# rate-limited (~100/day). Point at the paid tier or another provider here.
BARCODE_API_URL=https://api.upcitemdb.com/prod/trial

# --- Style Jury (outfit rating + simulated public opinion) ---
# Any OpenAI-compatible endpoint. Examples:
#   Ollama (free, local):  LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=llama3.2
#   Groq (free tier):      LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.3-70b-versatile
#   OpenRouter (free):     LLM_BASE_URL=https://openrouter.ai/api/v1  LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Gemini (free tier):    LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  LLM_MODEL=gemini-2.0-flash
# Leave LLM_BASE_URL empty to use the built-in deterministic jury (no API calls).
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Set true only if the model accepts image inputs — the jury then sees the photo
LLM_VISION=false
