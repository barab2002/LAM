{
  "expo": {
    "name": "LAM",
    "slug": "lam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lam",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "LAM uses the camera to capture your clothes and outfits.",
        "NSLocationWhenInUseUsageDescription": "LAM uses your location to match outfit suggestions to the local weather."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "LAM uses the camera to capture your clothes and outfits."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LAM uses your location to match outfit suggestions to the local weather."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#C4664B",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
